        },
        {
          "sku": "H100 NVL",
          "matchAny": ["H100 NVL"],
          "excludeAny": ["Virtual Workstation", "vWS"],
          "gpuCount": 1
        },
        {
          "sku": "H200 SXM",
          "matchAny": ["H200"],
          "excludeAny": ["Virtual Workstation", "vWS"],
          "gpuCount": 1
        },
        {
          "sku": "B200",
          "matchAny": ["B200"],
          "excludeAny": ["Virtual Workstation", "vWS"],
          "gpuCount": 1
        }
      ]
    }
  }

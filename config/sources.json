      "frequency": "daily",
      "requiresEnv": "VAST_API_KEY"
    },
    "gcpSpot": {
      "platform": "GCP Spot",
      "frequency": "daily",
      "serviceId": "6F81-5844-456A",
      "apiKeyEnv": "GCP_BILLING_API_KEY",
      "inputFile": "data/manual/gcp-spot.json",
      "remoteEnv": "GCP_SPOT_JSON_URL",
      "regions": ["us-central1", "us-east5", "us-west4"],
      "targets": [
        {
          "sku": "H100 SXM",
          "matchAny": ["H100"],
          "excludeAny": ["H100 NVL", "Virtual Workstation", "vWS"],
